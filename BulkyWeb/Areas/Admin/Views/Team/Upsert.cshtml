@model TeamVM

<style>
    :root {
        --hf-navy: #0b1f4b;
        --hf-blue: #2ea3ff;
        --hf-bg: #f6f8fc;
        --hf-card: #ffffff;
        --hf-muted: #64748b;
        --hf-danger: #dc3545;
    }

    body {
        background: var(--hf-bg);
    }

    .admin-wrap {
        padding: 48px 12px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .admin-card {
        background: var(--hf-card);
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,.06);
        box-shadow: 0 18px 45px rgba(0,0,0,.10);
        overflow: hidden;
        margin-top: 24px;
    }

    .admin-head {
        background: linear-gradient(90deg, rgba(46,163,255,.25), transparent 60%), var(--hf-navy);
        color: #fff;
        text-align: center;
        font-weight: 900;
        letter-spacing: 2px;
        padding: 24px 16px;
        font-size: 1.5rem;
    }

    .admin-body {
        padding: 32px 24px;
    }

    .btn-main {
        background: var(--hf-navy);
        border: 0;
        color: #fff;
        font-weight: 900;
        border-radius: 14px;
        padding: 12px 20px;
        box-shadow: 0 16px 34px rgba(11,31,75,.18);
        transition: all 0.3s ease;
    }

        .btn-main:hover {
            background: #0E2958;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(11,31,75,.25);
        }

    .btn-soft {
        border-radius: 12px;
        padding: 9px 16px;
        font-weight: 800;
        border: 1px solid rgba(11,31,75,.18);
        transition: all 0.25s ease;
        font-size: 0.9rem;
    }

    .btn-edit {
        background: rgba(11,31,75,.07);
        color: var(--hf-navy);
    }

        .btn-edit:hover {
            background: #0E2958;
            color: #fff;
            border-color: var(--hf-navy);
            transform: translateY(-1px);
        }

    .btn-delete {
        background: rgba(220,53,69,.08);
        color: var(--hf-danger);
        border-color: rgba(220,53,69,.22);
    }

        .btn-delete:hover {
            background: var(--hf-danger);
            color: #fff;
            border-color: var(--hf-danger);
            transform: translateY(-1px);
        }

    .form-label {
        font-weight: 700;
        color: var(--hf-navy);
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,.1);
        padding: 12px 16px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--hf-blue);
            box-shadow: 0 0 0 0.2rem rgba(46,163,255,.15);
        }

    .text-danger {
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 4px;
    }

    .form-check-input:checked {
        background-color: var(--hf-navy);
        border-color: var(--hf-navy);
    }

    .image-preview-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.1);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 16px;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

        .image-preview-card img {
            border-radius: 8px;
            border: 1px solid rgba(0,0,0,.1);
        }
</style>

<div class="container admin-wrap">
    <div class="admin-card">
        <div class="admin-head">@(Model.Team.Id != 0 ? "UPDATE" : "CREATE") TEAM</div>

        <div class="admin-body">
            <form method="post" enctype="multipart/form-data">
                <input asp-for="Team.Id" hidden />

                <div class="row">
                    <div class="col-lg-10">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Team.Title" class="form-label"></label>
                                <input asp-for="Team.Title" class="form-control" />
                                <span asp-validation-for="Team.Title" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Team.YearsOfExperience" class="form-label"></label>
                                <input asp-for="Team.YearsOfExperience" type="number" class="form-control" />
                                <span asp-validation-for="Team.YearsOfExperience" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Team.Description" class="form-label"></label>
                                <textarea asp-for="Team.Description" class="form-control" rows="4"></textarea>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Team.WorkersCount" class="form-label"></label>
                                <input asp-for="Team.WorkersCount" type="number" class="form-control" />
                                <span asp-validation-for="Team.WorkersCount" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Team.HourlyRate" class="form-label"></label>
                                <input asp-for="Team.HourlyRate" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="Team.HourlyRate" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Team.DepositAmount" class="form-label"></label>
                                <input asp-for="Team.DepositAmount" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="Team.DepositAmount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Team.ServiceId" class="form-label"></label>
                                <select asp-for="Team.ServiceId" asp-items="@Model.ServiceList" class="form-select">
                                    <option disabled selected>-- Select Category --</option>
                                </select>
                                <span asp-validation-for="Team.ServiceId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Team.TeamImages" class="form-label"></label>
                                <input type="file" name="files" class="form-control" multiple />
                            </div>

                            <div class="col-12">
                                <div class="form-check p-3" style="background: rgba(46,163,255,.06); border-radius: 12px;">
                                    <input asp-for="Team.IsAvailable24Hours" class="form-check-input" type="checkbox" />
                                    <label asp-for="Team.IsAvailable24Hours" class="form-check-label fw-bold"></label>
                                </div>
                                <span asp-validation-for="Team.IsAvailable24Hours" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <div class="d-flex gap-3 mt-3">
                                    @if (Model.Team.Id != 0)
                                    {
                                        <button type="submit" class="btn btn-main px-5">Update</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-main px-5">Create</button>
                                    }
                                    <a asp-controller="Team" asp-action="Index" class="btn btn-soft btn-edit px-5">
                                        Back To List
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2">
                        @if (Model.Team.TeamImages != null)
                        {
                            foreach (var image in Model.Team.TeamImages)
                            {
                                <div class="image-preview-card">
                                    <img src="@image.ImageUrl" class="w-100" />
                                    <a asp-action="DeleteImage" asp-route-imageId="@image.Id" class="btn btn-soft btn-delete w-100 mt-2">
                                        <i class="bi bi-trash-fill me-1"></i> Delete
                                    </a>
                                </div>
                            }
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        tinymce.init({
            selector: 'textarea',
            plugins: [
                'autolink', 'lists', 'charmap',
                'anchor', 'visualblocks',
                'wordcount', 'codesample', 'table'
            ],
            toolbar: 'undo redo | blocks | fontfamily fontsize | bold italic underline strikethrough | align lineheight | numlist bullist indent outdent'
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}
