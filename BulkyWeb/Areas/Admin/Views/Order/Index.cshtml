@{
    var status = Context.Request.Query["status"];
    var pending = "";
    var inprocess = "";
    var completed = "";
    var approved = "";
    var all = "active";

    switch (status)
    {
        case "pending":
            pending = "active"; all = ""; break;
        case "inprocess":
            inprocess = "active"; all = ""; break;
        case "completed":
            completed = "active"; all = ""; break;
        case "approved":
            approved = "active"; all = ""; break;
        default:
            all = "active"; break;
    }
}

<style>
    :root {
        --brand: #0b1f4b;
        --brand2: #0e2a66;
        --bg: #e8eef5;
        --muted: #64748b;
        --card: #fff;
        --line: rgba(0, 0, 0, .08);
        --shadow: 0 18px 45px rgba(0, 0, 0, .10);
    }

    body {
        background: var(--bg);
    }

   
    .admin-wrap {
        padding: 48px 12px;
        max-width: 1200px;
        margin: 0 auto;
    }


    .admin-card {
        background: var(--card);
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,.08);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .admin-head {
        background: linear-gradient(90deg, #0b1f4b, #0e2a66);
        color: #fff;
        text-align: center;
        font-weight: 900;
        letter-spacing: 2px;
        padding: 24px 16px;
        font-size: 1.5rem;
    }

 
    .order-list-card {
        background: #fff;
        border-radius: 0 0 18px 18px;
        overflow: hidden;
    }

   
    .status-tabs {
        display: flex;
        gap: 14px;
        justify-content: center;
        padding: 20px 16px;
        border-bottom: 1px solid var(--line);
        background: #fafbfc;
    }

    .status-tab {
        text-decoration: none;
        font-weight: 800;
        color: #6b7280;
        padding: 10px 16px;
        border-radius: 10px;
        transition: .2s;
    }

        .status-tab:hover {
            background: rgba(11, 31, 75, .06);
            color: var(--brand);
        }

        .status-tab.active {
            background: rgba(11, 31, 75, .12);
            color: var(--brand);
        }

   
    .table-controls {
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
        border-bottom: 1px solid var(--line);
        flex-wrap: wrap;
        gap: 12px;
    }

    .entries-select,
    .search-input {
        border-radius: 10px;
        border: 1px solid rgba(0,0,0,.12);
        padding: 6px 12px;
        font-weight: 700;
    }

    .search-input {
        min-width: 220px;
    }

 
    .table-wrapper {
        padding: 0 20px 20px;
    }

    table.dataTable {
        margin: 0 !important;
        border-collapse: collapse !important;
    }

        table.dataTable thead th {
            font-size: .8rem;
            text-transform: uppercase;
            color: #64748b;
            font-weight: 900;
            border-bottom: 2px solid var(--line);
            padding: 16px 14px;
        }

        table.dataTable tbody td {
            padding: 16px 14px;
            font-weight: 700;
            color: #0f172a;
            border-bottom: 1px solid rgba(0,0,0,.06);
        }

        table.dataTable tbody tr:hover {
            background: #fafbfc;
        }

  
    .btn-edit {
        background: var(--brand);
        color: #fff;
        width: 44px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 16px rgba(11, 31, 75, .2);
        transition: .2s;
        text-decoration: none;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            color: #fff;
        }

   
    .dataTables_length,
    .dataTables_filter {
        display: none !important;
    }
</style>

<div class="admin-wrap">
    <div class="admin-card">
        <div class="admin-head">ORDER LIST</div>

        <div class="order-list-card">

           
            <div class="status-tabs">
                <a asp-action="Index" asp-route-status="all" class="status-tab @all">All</a>
                <a asp-action="Index" asp-route-status="approved" class="status-tab @approved">Approved</a>
                <a asp-action="Index" asp-route-status="completed" class="status-tab @completed">Completed</a>
                <a asp-action="Index" asp-route-status="pending" class="status-tab @pending">Payment Pending</a>
                <a asp-action="Index" asp-route-status="inprocess" class="status-tab @inprocess">In Process</a>
            </div>

            
            <div class="table-controls">
                <div>
                    Show
                    <select id="entriesSelect" class="entries-select">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                    </select>
                    entries
                </div>

                <div>
                    Search:
                    <input id="tableSearch" class="search-input" />
                </div>
            </div>

            
            <div class="table-wrapper">
                <table id="tblData" class="table table-hover w-100">
                    <thead>
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>NAME</th>
                            <th>PHONE</th>
                            <th>EMAIL</th>
                            <th style="width:140px;">STATUS</th>
                            <th style="width:90px;"></th>
                        </tr>
                    </thead>
                </table>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/order.js"></script>

    <script>
        $(document).ready(function () {
            var table = $('#tblData').DataTable();

            $('#tableSearch').on('keyup', function () {
                table.search(this.value).draw();
            });

            $('#entriesSelect').on('change', function () {
                table.page.len(this.value).draw();
            });
        });
    </script>
}


