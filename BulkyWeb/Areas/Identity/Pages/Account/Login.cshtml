@page
@model LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Home Fix</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary-navy: #1e3a8a;
            --secondary-blue: #3b82f6;
            --light-blue: #60a5fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            height: 100%;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3a8a 100%);
            min-height: 100%;
            position: relative;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
                border-radius: 50%;
                top: -200px;
                right: -200px;
                animation: float 8s ease-in-out infinite;
            }

            body::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, rgba(96, 165, 250, 0.1) 0%, transparent 70%);
                border-radius: 50%;
                bottom: -150px;
                left: -150px;
                animation: float 10s ease-in-out infinite reverse;
            }

        @@keyframes float {
            0%, 100%

        {
            transform: translate(0, 0);
        }

        50% {
            transform: translate(30px, 30px);
        }

        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .login-container {
            width: 100%;
            max-width: 480px;
            position: relative;
            z-index: 10;
        }

        .brand-section {
            text-align: center;
            margin-bottom: 30px;
            animation: slideDown 0.6s ease-out;
        }

        @@keyframes slideDown {
            from

        {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .brand-logo {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--secondary-blue) 0%, var(--light-blue) 100%);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
        }

            .brand-logo i {
                font-size: 30px;
                color: white;
            }

        .brand-title {
            font-size: 32px;
            font-weight: 800;
            color: white;
            letter-spacing: 1px;
            margin: 0;
        }

        .brand-subtitle {
            color: rgba(255, 255, 255, 0.7);
            font-size: 15px;
            margin-top: 8px;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
            animation: slideUp 0.6s ease-out;
        }

        @@keyframes slideUp {
            from

        {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .login-header {
            text-align: center;
            margin-bottom: 35px;
        }

            .login-header h2 {
                font-size: 28px;
                font-weight: 700;
                color: var(--primary-navy);
                margin-bottom: 8px;
            }

            .login-header p {
                color: #64748b;
                font-size: 15px;
            }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-navy);
            margin-bottom: 10px;
            font-size: 14px;
            display: block;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
            transition: color 0.3s ease;
        }

        .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            padding: 14px 16px 14px 48px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: #f8fafc;
            width: 100%;
        }

            .form-control:focus {
                border-color: var(--secondary-blue);
                background: white;
                box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
                outline: none;
            }

                .form-control:focus ~ .input-icon {
                    color: var(--secondary-blue);
                }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
            cursor: pointer;
            transition: color 0.3s ease;
            z-index: 10;
        }

            .password-toggle:hover {
                color: var(--secondary-blue);
            }

        .form-check {
            margin: 20px 0;
        }

        .form-check-input {
            width: 18px;
            height: 18px;
            border: 2px solid #cbd5e1;
            border-radius: 6px;
            cursor: pointer;
        }

            .form-check-input:checked {
                background-color: var(--secondary-blue);
                border-color: var(--secondary-blue);
            }

        .form-check-label {
            font-size: 14px;
            color: #475569;
            margin-left: 8px;
            cursor: pointer;
        }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, var(--primary-navy) 0%, var(--secondary-blue) 100%);
            border: none;
            color: white;
            padding: 16px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 700;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.3);
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 35px rgba(30, 58, 138, 0.4);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .divider {
            text-align: center;
            margin: 30px 0;
            position: relative;
        }

            .divider::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                width: 100%;
                height: 1px;
                background: #e2e8f0;
            }

            .divider span {
                background: rgba(255, 255, 255, 0.95);
                padding: 0 15px;
                color: #94a3b8;
                font-size: 14px;
                font-weight: 600;
                position: relative;
                z-index: 1;
            }

        .links-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 20px;
        }

            .links-section a {
                color: var(--secondary-blue);
                text-decoration: none;
                font-size: 14px;
                font-weight: 600;
                transition: color 0.3s ease;
            }

                .links-section a:hover {
                    color: var(--primary-navy);
                    text-decoration: underline;
                }

        .register-section {
            text-align: center;
            margin-top: 30px;
            padding-top: 25px;
            border-top: 1px solid #e2e8f0;
        }

            .register-section p {
                color: #64748b;
                font-size: 14px;
                margin-bottom: 12px;
            }

        .btn-register {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--primary-navy);
            font-weight: 700;
            text-decoration: none;
            padding: 10px 24px;
            border: 2px solid var(--secondary-blue);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .btn-register:hover {
                background: var(--secondary-blue);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
            }

        .text-danger {
            color: #ef4444;
            font-size: 13px;
            margin-top: 6px;
            display: block;
        }

        .alert {
            border-radius: 12px;
            margin-bottom: 24px;
            border: none;
        }

        
        @@media (max-width: 576px) {
            .login-wrapper

        {
            padding: 30px 15px;
        }

        .login-card {
            padding: 30px 24px;
        }

        .brand-title {
            font-size: 26px;
        }

        .brand-logo {
            width: 50px;
            height: 50px;
        }

            .brand-logo i {
                font-size: 24px;
            }

        .login-header h2 {
            font-size: 24px;
        }

        .links-section {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }

        .brand-section {
            margin-bottom: 20px;
        }

        }

        @@media (max-height: 750px) {
            .login-wrapper

        {
            padding: 25px 20px;
        }

        .brand-section {
            margin-bottom: 20px;
        }

        .login-card {
            padding: 30px;
        }

        .login-header {
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        }

        @@media (max-height: 650px) {
            .login-wrapper

        {
            padding: 20px 15px;
        }

        .brand-section {
            margin-bottom: 15px;
        }

        .brand-logo {
            width: 45px;
            height: 45px;
            margin-bottom: 10px;
        }

            .brand-logo i {
                font-size: 22px;
            }

        .brand-title {
            font-size: 24px;
        }

        .brand-subtitle {
            font-size: 13px;
        }

        .login-card {
            padding: 25px 20px;
        }

        .login-header {
            margin-bottom: 20px;
        }

            .login-header h2 {
                font-size: 22px;
            }

        .form-group {
            margin-bottom: 16px;
        }

        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-container">
         
            <div class="brand-section">
                <div class="brand-logo">
                    <i class="bi bi-house-fill"></i>
                </div>
                <h1 class="brand-title">HOME FIX</h1>
                <p class="brand-subtitle">Your Home Service Partner</p>
            </div>

           
            <div class="login-card">
                <div class="login-header">
                    <h2>Welcome Back!</h2>
                    <p>Login to manage your services</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger" role="alert"></div>

                   
                    <div class="form-group">
                        <label asp-for="Input.Email" class="form-label">Email Address</label>
                        <div class="input-wrapper">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   aria-required="true" placeholder="Enter your email" />
                            <i class="bi bi-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                   
                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <div class="input-wrapper">
                            <input asp-for="Input.Password" type="password" class="form-control" id="passwordInput"
                                   autocomplete="current-password" aria-required="true" placeholder="Enter your password" />
                            <i class="bi bi-lock input-icon"></i>
                            <i class="bi bi-eye password-toggle" id="togglePassword"></i>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                  
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Remember me on this device
                        </label>
                    </div>

                  
                    <button id="login-submit" type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right"></i> Login to Account
                    </button>

                   
                    <div class="links-section">
                        <a id="forgot-password" asp-page="./ForgotPassword">
                            <i class="bi bi-key"></i> Forgot Password?
                        </a>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                            <i class="bi bi-envelope-check"></i> Resend Confirmation
                        </a>
                    </div>

                 
                    <div class="divider">
                        <span>OR</span>
                    </div>

                    
                    <div class="register-section">
                        <p>Don't have an account yet?</p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn-register">
                            <i class="bi bi-person-plus"></i>
                            Create New Account
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
       
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('passwordInput');

        if (togglePassword && passwordInput) {
            togglePassword.addEventListener('click', function () {
                
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                
                this.classList.toggle('bi-eye');
                this.classList.toggle('bi-eye-slash');
            });
        }
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
