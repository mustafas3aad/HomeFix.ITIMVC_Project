@{
    Layout = "_Layout";
}


 @model IEnumerable<Team>

<section class="py-5">
    <div class="container">
     
        <div class="category-header d-flex align-items-end justify-content-between flex-wrap gap-2 mb-5">
            <div>
              
                <h2 class="category-title mb-0">
                    Explore Our <span class="category-accent">services</span>
                </h2>
                <p class="category-sub mb-0 mt-2">
                    Choose a service to get started — fast, reliable, and professional.
                </p>
            </div>
        </div>

        <div class="row g-4 categorie">
            @foreach (var worker in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="Details" asp-route-ProductId="@worker.Id" class="category-card">
                        @if (worker.TeamImages != null && worker.TeamImages.Count() > 0)
                        {
                            <img src="@worker.TeamImages.FirstOrDefault().ImageUrl" alt="@worker.Title">
                        }
                        else
                        {
                            <img src="https://placehold.co/600x400/0b1f4b/ffffff?text=@worker.Title" alt="@worker.Title">
                        }
                        <div class="category-overlay">
                            <h5 class="category-title">@worker.Title</h5>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<style>
    
    .category-kicker {
        color: #6b7280;
        font-weight: 600;
        font-size: .85rem;
    }

    .category-title {
        font-weight: 800;
        color: #0b1f4b;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.1;
    }

    .category-accent {
        color: #2ea3ff;
    }

    .category-sub {
        color: #64748b;
        font-size: 1rem;
        max-width: 520px;
    }

    
    .categorie .category-card {
        position: relative;
        display: block;
        border-radius: 22px;
        overflow: hidden;
        height: 320px;
        text-decoration: none;
        background: #0b1f4b;
        box-shadow: 0 14px 32px rgba(0, 0, 0, .12);
        border: 1px solid rgba(0, 0, 0, .06);
        transition: transform .25s ease, box-shadow .25s ease;
    }

    .categorie .category-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scale(1.02);
        transition: transform .35s ease, filter .35s ease;
        filter: contrast(1.02) saturate(1.05);
    }

    .categorie .category-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 18px;
        background: linear-gradient(to top, rgba(11, 31, 75, .85) 0%, rgba(11, 31, 75, .15) 55%, rgba(11, 31, 75, 0) 100%);
        transition: background .35s ease;
    }

    .categorie .category-title {
        margin: 0;
        color: #fff;
        font-weight: 800;
        font-size: 1.15rem;
        line-height: 1.2;
        text-shadow: 0 10px 26px rgba(0, 0, 0, .35);
    }

    .categorie .category-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 46px rgba(0, 0, 0, .18);
    }

    .categorie .category-card:hover img {
        transform: scale(1.08);
        filter: contrast(1.05) saturate(1.12);
    }

    .categorie .category-card:hover .category-overlay {
        background: linear-gradient(to top, rgba(11, 31, 75, .92) 0%, rgba(11, 31, 75, .22) 55%, rgba(11, 31, 75, 0) 100%);
    }

    @@media (max-width: 576px) {
        .categorie .category-card {
            height: 240px;
            border-radius: 18px;
        }

        .categorie .category-title {
            font-size: 1.05rem;
        }
    }
</style>