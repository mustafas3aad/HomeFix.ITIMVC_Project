@model BookingCart

<style>
    body {
        background: #f6f8fc;
    }

    .service-hero {
        margin-top: 60px;
        padding: 0;
    }

        .service-hero .hero-content {
            background: radial-gradient(900px 350px at 50% 0%, rgba(46, 163, 255, .25), transparent 60%), #0b1f4b;
            color: #fff;
            padding: 44px;
            border-radius: 22px 22px 22px 22px;
        }

        .service-hero h1 {
            font-weight: 900;
            margin: 0;
            font-size: clamp(26px, 3.5vw, 44px);
        }

        .service-hero p {
            color: rgba(255, 255, 255, .75);
            margin: 10px 0 0;
            max-width: 720px;
        }

    .card-soft {
        border-radius: 22px;
        background: #fff;
        border: 1px solid rgba(0, 0, 0, .06);
        box-shadow: 0 18px 45px rgba(0, 0, 0, .10);
        overflow: hidden;
    }

    .service-img {
        width: 100%;
        height: 100%;
        min-height: 360px;
        object-fit: cover;
        display: block;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 800;
        font-size: .9rem;
        background: rgba(46, 163, 255, .12);
        color: #0b1f4b;
        border: 1px solid rgba(46, 163, 255, .25);
    }

    .team-line {
        color: #64748b;
        font-weight: 700;
        margin-top: 12px;
        line-height: 1.7;
    }

    .kv {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px dashed rgba(0, 0, 0, .10);
        font-weight: 800;
        color: #0b1f4b;
    }

        .kv:last-child {
            border-bottom: 0;
        }

        .kv .v {
            color: #334155;
            font-weight: 900;
            text-align: end;
        }

    .note {
        color: #64748b;
        font-weight: 600;
        font-size: .95rem;
        line-height: 1.6;
        margin-top: 14px;
    }

    .btn-cart {
        background: #0b1f4b;
        border: 0;
        color: #fff;
        font-weight: 900;
        border-radius: 14px;
        padding: 12px 18px;
        width: 100%;
        margin-top: 16px;
        box-shadow: 0 16px 34px rgba(11, 31, 75, .22);
        text-transform: uppercase;
        letter-spacing: .6px;
        transition: filter .2s ease;
    }

        .btn-cart:hover {
            filter: brightness(1.06);
            color: #fff;
        }

    .back-btn {
        background: #fff;
        border: 0;
        border-radius: 999px;
        padding: 10px 18px;
        font-weight: 800;
        box-shadow: 0 14px 30px rgba(0, 0, 0, .10);
        transition: transform .2s ease;
    }

        .back-btn:hover {
            transform: translateY(-2px);
        }

    .carousel-inner img {
        border-radius: 18px;
    }

    @@media (max-width: 992px) {
        .service-img {
            min-height: 260px;
        }
    }
</style>

<form method="post">
    <input hidden asp-for="TeamId" />

    <!-- Hero Header -->
    <header class="service-hero">
        <div class="container">
            <div class="hero-content">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <h1>@Model.Team.Service.Name</h1>
                        <p>
                            Browse examples of our work and choose the service you need. Fast response, trusted technicians.
                        </p>
                    </div>

                    <a asp-action="Index" class="back-btn">
                        <i class="bi bi-arrow-left me-2"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Service Details Section -->
    <section class="pb-5" style="margin-top: -22px;">
        <div class="container">
            <div class="card-soft">
                <div class="row g-0">

                    <!-- Image Column -->
                    <div class="col-lg-5">
                        @if (Model.Team.TeamImages != null && Model.Team.TeamImages.Count > 0)
                        {
                            <div id="carouselExampleIndicators" class="carousel slide h-100" data-bs-ride="carousel">
                                <div class="carousel-indicators">
                                    @foreach (var imageWithIndex in Model.Team.TeamImages.Select((image, index) => new { Image = image, Index = index }))
                                    {
                                        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="@imageWithIndex.Index"
                                                class="@(imageWithIndex.Index == 1 ? "active" : "")" aria-current="@(imageWithIndex.Index == 1 ? "true" : "false")" aria-label="Slide @(imageWithIndex.Index + 1)"></button>
                                    }
                                </div>
                                <div class="carousel-inner h-100">
                                    @foreach (var imageWithIndex in Model.Team.TeamImages.Select((image, index) => new { Image = image, Index = index }))
                                    {
                                        <div class="@(imageWithIndex.Index == 1 ? "carousel-item active h-100" : "carousel-item h-100")">
                                            <img src="@imageWithIndex.Image.ImageUrl" class="service-img" alt="@Model.Team.Title">
                                        </div>
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            </div>
                        }
                        else
                        {
                            <img src="https://placehold.co/600x400/0b1f4b/ffffff?text=@Model.Team.Title" class="service-img" alt="@Model.Team.Title">
                        }
                    </div>

                    <!-- Details Column -->
                    <div class="col-lg-7">
                        <div class="p-4 p-md-5">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <span class="pill">@Model.Team.Service.Name</span>
                                <span class="pill">
                                    <i class="bi bi-stars"></i>
                                    Trusted Team
                                </span>
                            </div>

                            <div class="team-line">
                                <div><strong>@Model.Team.Title</strong></div>
                                <div>Years Of Experience: <span>@Model.Team.YearsOfExperience</span></div>
                                <div>Number of Workers in Team: <span>@Model.Team.WorkersCount</span></div>
                            </div>

                            <div class="mt-4">
                                <div class="kv">
                                    <span>Deposit Price</span>
                                    <span class="v">@Model.Team.DepositAmount</span>
                                </div>
                                <div class="kv">
                                    <span>Hourly Rate</span>
                                    <span class="v">@Model.Team.HourlyRate</span>
                                </div>
                                <div class="kv">
                                    <span>Is Available 24 Hours</span>
                                    <span class="v">@Model.Team.IsAvailable24Hours</span>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Team.DepositNote))
                                {
                                    <p class="note">
                                        @Model.Team.DepositNote
                                    </p>
                                }

                                @if (!string.IsNullOrEmpty(Model.Team.Description))
                                {
                                    <p class="note mt-3">
                                        @Html.Raw(Model.Team.Description)
                                    </p>
                                }

                                <button type="submit" class="btn-cart">
                                    ADD TO CART
                                </button>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>






