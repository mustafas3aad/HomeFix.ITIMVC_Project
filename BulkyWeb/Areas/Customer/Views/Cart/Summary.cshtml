@model BookingCartVM

<style>
    :root {
        --brand: #0b1f4b;
        --brand2: #0e2a66;
        --bg: #e8eef5;
        --muted: #64748b;
        --card: #fff;
        --line: rgba(0, 0, 0, .08);
        --shadow: 0 4px 12px rgba(0, 0, 0, .08);
    }

    body {
        background: var(--bg);
    }


    .summary-header-section {
        background: linear-gradient(90deg, #0b1f4b, #0e2a66);
        padding: 24px 32px;
        border-radius: 16px 16px 0 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .1);
        margin-bottom: 0;
    }

    .page-title {
        color: #fff;
        margin: 0;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        font-size: 1.25rem;
    }

    .btn-back-cart {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, .3);
        color: #fff;
        font-weight: 700;
        border-radius: 25px;
        padding: 8px 24px;
        text-transform: capitalize;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back-cart:hover {
            background: rgba(255, 255, 255, .1);
            border-color: rgba(255, 255, 255, .5);
            color: #fff;
        }


    .summary-main-card {
        border-radius: 0 0 16px 16px;
        background: var(--card);
        border: none;
        box-shadow: var(--shadow);
        overflow: hidden;
        padding: 32px;
    }


    .summary-section-title {
        font-weight: 900;
        letter-spacing: 0.6px;
        color: var(--brand);
        text-transform: uppercase;
        font-size: 0.95rem;
        margin: 0 0 20px;
    }

   
    .field-label {
        font-weight: 800;
        color: var(--muted);
        font-size: 0.85rem;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        display: block;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, .10);
        padding: 12px 16px;
        font-weight: 600;
        transition: all 0.2s;
    }

        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(11, 31, 75, .1);
        }

   
    .summary-items-box {
        border-radius: 14px;
        border: 1px solid rgba(0, 0, 0, .08);
        background: linear-gradient(180deg, rgba(11, 31, 75, .04), transparent);
        padding: 20px;
    }

    .summary-cart-item {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px dashed rgba(0, 0, 0, .12);
    }

        .summary-cart-item:last-child {
            border-bottom: 0;
            padding-top: 16px;
            margin-top: 8px;
            border-top: 2px solid rgba(0, 0, 0, .15);
        }

    .summary-item-name {
        font-weight: 900;
        color: var(--brand);
        text-transform: uppercase;
        font-size: 0.9rem;
        margin-bottom: 4px;
    }

    .summary-item-qty {
        color: var(--muted);
        font-weight: 600;
        font-size: 0.85rem;
    }

    .summary-item-price {
        color: #0f172a;
        font-weight: 900;
        text-align: end;
        white-space: nowrap;
        font-size: 1rem;
    }

    .summary-total-label {
        font-weight: 900;
        color: var(--brand);
        text-transform: uppercase;
        font-size: 0.95rem;
    }

    .summary-total-value {
        color: #0f172a;
        font-weight: 900;
        font-size: 1.3rem;
    }

   
    .btn-place-order-custom {
        width: 100%;
        border: 0;
        background: linear-gradient(90deg, #0b1f4b, #0e2a66);
        color: #fff;
        font-weight: 900;
        border-radius: 12px;
        padding: 14px 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 8px 20px rgba(11, 31, 75, .25);
        transition: all 0.3s;
        margin-top: 20px;
    }

        .btn-place-order-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(11, 31, 75, .35);
            color: #fff;
        }

 
    .estimated-arrival {
        color: var(--muted);
        font-weight: 700;
        font-size: 0.9rem;
        margin-top: 20px;
    }


    .text-danger {
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 4px;
    }


    @@media (max-width: 768px) {
        .summary-header-section

    {
        padding: 20px 16px;
    }

    .summary-main-card {
        padding: 20px;
    }

    .summary-section-title {
        text-align: left !important;
    }

    }
</style>

<form method="post">
    <input type="hidden" asp-for="orderHeader.ApplicationUserId" />

   
    <div class="container mt-5 pt-3">
        <div class="summary-header-section">
            <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
                <h1 class="page-title">ORDER SUMMARY</h1>
                <a asp-action="Index" class="btn-back-cart">
                    <i class="bi bi-arrow-left"></i>
                    Back to Cart
                </a>
            </div>
        </div>


        <div class="summary-main-card">
            <div class="row g-4">

             
                <div class="col-lg-6">
                    <div class="pe-lg-4">
                        <h2 class="summary-section-title">Shipping Details:</h2>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="field-label">Name</label>
                                <input asp-for="orderHeader.Name" class="form-control" placeholder="Name" />
                                <span asp-validation-for="orderHeader.Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="field-label">Phone</label>
                                <input asp-for="orderHeader.PhoneNumber" class="form-control" placeholder="Phone" />
                                <span asp-validation-for="orderHeader.PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="field-label">Street Address</label>
                                <input asp-for="orderHeader.StreetAddress" class="form-control" placeholder="Street Address" />
                                <span asp-validation-for="orderHeader.StreetAddress" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="field-label">City</label>
                                <input asp-for="orderHeader.City" class="form-control" placeholder="City" />
                                <span asp-validation-for="orderHeader.City" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="field-label">State</label>
                                <input asp-for="orderHeader.State" class="form-control" placeholder="State" />
                                <span asp-validation-for="orderHeader.State" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="estimated-arrival">
                            Estimated Arrival Date: @DateTime.Now.AddHours(2).ToShortDateString() - @DateTime.Now.AddHours(4).ToShortDateString()
                        </div>
                    </div>
                </div>

               
                <div class="col-lg-6">
                    <div class="ps-lg-4">
                        <h2 class="summary-section-title text-lg-end">Order Summary:</h2>

                        <div class="summary-items-box">
                            @{
                                var cartList = Model.BookingCartList.ToList();
                            }

                            @for (int i = 0; i < cartList.Count; i++)
                            {
                                
                                <input type="hidden" asp-for="@Model.BookingCartList.ToList()[i].Id" />
                                <input type="hidden" asp-for="@Model.BookingCartList.ToList()[i].TeamId" />
                                <input type="hidden" asp-for="@Model.BookingCartList.ToList()[i].Count" />
                                <input type="hidden" asp-for="@Model.BookingCartList.ToList()[i].Price" />

                                <div class="summary-cart-item">
                                    <div>
                                        <div class="summary-item-name">@cartList[i].Team.Title</div>
                                        <div class="summary-item-qty">Quantity: @cartList[i].Count</div>
                                    </div>
                                    <div class="summary-item-price">
                                        @((cartList[i].Price * cartList[i].Count).ToString("c"))
                                    </div>
                                </div>
                            }

                         
                            <div class="summary-cart-item">
                                <div class="summary-total-label">Total (USD)</div>
                                <div class="summary-total-value">@Model.orderHeader.OrderTotal.ToString("c")</div>
                            </div>

                            <input type="hidden" asp-for="orderHeader.OrderTotal" />
                        </div>

                        <button type="submit" class="btn-place-order-custom">
                            PLACE ORDER
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
