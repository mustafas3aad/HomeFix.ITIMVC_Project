 @model Feedback
<style>
    .details-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        padding: 60px 0;
        margin-bottom: 40px;
        margin-top: 80px;
    }

    .details-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .details-header {
        background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
        padding: 30px;
        border-bottom: 4px solid #3b82f6;
    }

    .info-row {
        padding: 20px;
        border-bottom: 1px solid #f3f4f6;
        transition: all 0.3s ease;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-row:hover {
        background-color: #f9fafb;
    }

    .info-label {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
    }

    .info-label i {
        color: #3b82f6;
        margin-right: 8px;
        font-size: 20px;
    }

    .info-value {
        color: #6b7280;
        font-size: 16px;
    }

    .user-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        font-weight: 700;
        margin-right: 15px;
    }

    .service-badge-large {
        background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        display: inline-block;
    }

    .rating-display {
        background: #fef3c7;
        padding: 15px 25px;
        border-radius: 15px;
        display: inline-block;
    }

    .rating-stars-large i {
        font-size: 28px;
        margin-right: 5px;
    }

    .comment-box {
        background: #f9fafb;
        border-left: 4px solid #3b82f6;
        padding: 25px;
        border-radius: 10px;
        font-size: 16px;
        line-height: 1.8;
        color: #374151;
    }

    .btn-back {
        background: white;
        border: 2px solid #3b82f6;
        color: #3b82f6;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-back:hover {
        background: #3b82f6;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

    .date-badge {
        background: #e5e7eb;
        color: #4b5563;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
    }

    .feedback-id {
        background: #dbeafe;
        color: #1e40af;
        padding: 5px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

<div class="details-hero text-white text-center">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2">Feedback Details</h1>
        <p class="lead mb-0">Complete information about this feedback</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card details-card">
                <div class="details-header text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold">
                            <i class="bi bi-clipboard-check me-2"></i>Feedback Information
                        </h4>
                        <span class="feedback-id">ID: #@Model.Id</span>
                    </div>
                </div>

                <div class="card-body p-0">
                  
                    <div class="info-row">
                        <div class="info-label">
                            <i class="bi bi-person-circle"></i>
                            Customer Name
                        </div>
                        <div class="d-flex align-items-center mt-2">
                            <div class="user-avatar">
                                @Model.UserName.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">@Model.UserName</h5>
                                <small class="text-muted">Verified Customer</small>
                            </div>
                        </div>
                    </div>

                 
                    <div class="info-row">
                        <div class="info-label">
                            <i class="bi bi-tools"></i>
                            Service Type
                        </div>
                        <div class="mt-2">
                            <span class="service-badge-large">
                                <i class="bi bi-gear-fill me-2"></i>@Model.Service?.Name
                            </span>
                        </div>
                    </div>

                
                    <div class="info-row">
                        <div class="info-label">
                            <i class="bi bi-calendar-event"></i>
                            Feedback Date
                        </div>
                        <div class="mt-2">
                            <span class="date-badge">
                                <i class="bi bi-clock-history me-2"></i>
                                @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")
                            </span>
                        </div>
                    </div>

                
                    <div class="info-row">
                        <div class="info-label">
                            <i class="bi bi-star-fill"></i>
                            Service Rating
                        </div>
                        <div class="mt-3">
                            <div class="rating-display">
                                <div class="rating-stars-large">
                                    @for (int i = 0; i < Model.Rating; i++)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    @for (int i = Model.Rating; i < 5; i++)
                                    {
                                        <i class="bi bi-star text-muted"></i>
                                    }
                                </div>
                                <div class="mt-2">
                                    <strong class="text-dark">@Model.Rating out of 5 Stars</strong>
                                    <span class="ms-2">
                                        @switch (Model.Rating)
                                        {
                                            case 5:
                                                <span class="badge bg-success">Excellent</span>
                                                break;
                                            case 4:
                                                <span class="badge bg-primary">Very Good</span>
                                                break;
                                            case 3:
                                                <span class="badge bg-info">Good</span>
                                                break;
                                            case 2:
                                                <span class="badge bg-warning">Fair</span>
                                                break;
                                            case 1:
                                                <span class="badge bg-danger">Poor</span>
                                                break;
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                
                    <div class="info-row">
                        <div class="info-label">
                            <i class="bi bi-chat-left-quote"></i>
                            Customer Feedback
                        </div>
                        <div class="mt-3">
                            <div class="comment-box">
                                <i class="bi bi-quote text-primary" style="font-size: 30px; opacity: 0.3;"></i>
                                <p class="mb-0 mt-2" style="white-space: pre-wrap;">@Model.Comment</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4 text-center">
                    <a asp-action="Index" class="btn btn-back">
                        <i class="bi bi-arrow-left-circle me-2"></i>Back to Feedback List
                    </a>
                </div>
            </div>

          
            <div class="text-center mt-4">
                <p class="text-muted">
                    <i class="bi bi-shield-check me-1"></i>
                    This feedback was submitted securely and is being used to improve our services
                </p>
            </div>
        </div>
    </div>
</div>
