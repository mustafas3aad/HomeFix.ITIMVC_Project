@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Home Fix</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="//cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css" />

    <style>
      
        .top-nav {
            background-color: #0F1D58;
            transition: all .25s ease;
        }

            .top-nav.nav-sticky {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                z-index: 9999;
                background: rgba(11, 31, 75, .92);
                backdrop-filter: blur(10px);
                box-shadow: 0 12px 30px rgba(0, 0, 0, .18);
            }

        body.has-sticky {
            padding-top: 72px;
        }

        .brand-wrap {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            letter-spacing: .4px;
            text-decoration: none;
        }

        .brand-icon {
            width: 30px;
            height: 30px;
            border-radius: 10px;
            background: rgba(46, 163, 255, .18);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(46, 163, 255, .35);
        }

            .brand-icon i {
                color: #2ea3ff;
                font-size: 16px;
            }

        .brand-text {
            font-size: 1.15rem;
        }

        .navbar .nav-link {
            position: relative;
            font-weight: 500;
            padding: .6rem .9rem;
            transition: color .25s ease, transform .25s ease, background .25s ease;
        }

            .navbar .nav-link:hover {
                color: #2ea3ff !important;
                transform: translateY(-1px);
                background: rgba(46, 163, 255, .1);
                border-radius: 999px;
            }

        .icon-btn {
            width: 32px;
            height: 32px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, .2);
            background: transparent;
            transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
        }

            .icon-btn:hover {
                color: #2ea3ff;
                border-color: rgba(46, 163, 255, .5);
                transform: translateY(-1px);
                box-shadow: 0 10px 22px rgba(0, 0, 0, .10);
            }

        .btn-soft {
            border-radius: 12px;
            transition: transform .2s ease, box-shadow .2s ease;
        }

            .btn-soft:hover {
                transform: translateY(-1px);
                box-shadow: 0 10px 22px rgba(0, 0, 0, .10);
            }

       
        .site-footer {
            background: #15a9e6;
            color: #fff;
            padding: 34px 0 22px;
            position: relative;
            overflow: hidden;
            margin-top: 50px;
        }

        .newsletter-box {
            background: rgba(255, 255, 255, .18);
            border: 1px solid rgba(255, 255, 255, .22);
            border-radius: 18px;
            padding: 18px 18px;
        }

        .newsletter-title {
            font-weight: 800;
            margin: 0;
        }

        .newsletter-sub {
            color: rgba(255, 255, 255, .85);
            font-size: .95rem;
        }

        .newsletter-form {
            background: #fff;
            border-radius: 999px;
            padding: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 16px 34px rgba(0, 0, 0, .12);
        }

        .newsletter-input {
            border: 0;
            outline: none;
            padding: 10px 14px;
            flex: 1;
            border-radius: 999px;
            font-weight: 600;
            color: #0b1f4b;
        }

            .newsletter-input::placeholder {
                color: #94a3b8;
                font-weight: 600;
            }

        .newsletter-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 20px;
            font-weight: 800;
            color: #fff;
            background: #0ea5e9;
            transition: transform .2s ease, filter .2s ease;
        }

            .newsletter-btn:hover {
                filter: brightness(1.05);
                transform: translateY(-1px);
            }

        .footer-brand-icon {
            width: 34px;
            height: 34px;
            border-radius: 12px;
            background: rgba(255, 255, 255, .22);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255, 255, 255, .22);
        }

        .footer-brand-text {
            font-size: 1.6rem;
            font-weight: 900;
            letter-spacing: .3px;
        }

        .footer-desc {
            color: rgba(255, 255, 255, .88);
            max-width: 420px;
            line-height: 1.6;
        }

        .footer-social a {
            width: 36px;
            height: 36px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            text-decoration: none;
            background: rgba(255, 255, 255, .18);
            border: 1px solid rgba(255, 255, 255, .18);
            transition: transform .2s ease, background .2s ease;
        }

            .footer-social a:hover {
                transform: translateY(-2px);
                background: rgba(255, 255, 255, .26);
            }

        .footer-heading {
            font-weight: 900;
            margin-bottom: 12px;
        }

        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 10px;
        }

            .footer-links a {
                color: rgba(255, 255, 255, .88);
                text-decoration: none;
                transition: color .2s ease, transform .2s ease;
            }

                .footer-links a:hover {
                    color: #fff;
                    transform: translateX(2px);
                }

        .footer-line {
            border-color: rgba(255, 255, 255, .22);
            margin: 28px 0 14px;
        }

        .footer-copy {
            color: rgba(255, 255, 255, .85);
            font-weight: 600;
            font-size: .95rem;
        }

        @@media (max-width: 991px) {
            .newsletter-form {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    
    <header>
        <nav class="navbar navbar-expand-lg top-nav" id="mainNav">
            <div class="container-fluid">
                <a class="navbar-brand brand-wrap text-light px-5" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">
                        <i class="bi bi-house-fill"></i>
                    </span>
                    <span class="brand-text">HOME FIX</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarScroll"
                        aria-controls="navbarScroll" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarScroll">
                    <ul class="navbar-nav me-auto my-2 my-lg-0 navbar-nav-scroll" style="--bs-scroll-height: 100px;">
                        <li class="nav-item">
                            <a class="nav-link nav-anim active text-light" asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-anim text-light px-3" asp-area="Admin" asp-controller="Order" asp-action="Index">Manage Order</a>
                        </li>

                        @if (User.IsInRole(SD.Role_Admin))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Content Management
                                </a>
                                <ul class="dropdown-menu">
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Service" asp-action="Index">Service</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Team" asp-action="Index">Team</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Company" asp-action="Index">Company</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register">Create User</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">User Manage</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-controller="Feedback" asp-action="Index">Feedback</a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                              
                                @await Component.InvokeAsync("BookingCart")
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

  
    <div class="container">
        <main role="main" class="pb-3">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>


    <footer class="site-footer">
        <div class="container">

            <div class="row mt-5 gy-4">
                
                <div class="col-lg-5">
                    <div class="footer-brand d-flex align-items-center gap-2">
                        <span class="footer-brand-icon"><i class="bi bi-house-fill"></i></span>
                        <span class="footer-brand-text">Home Fix</span>
                    </div>

                    <p class="footer-desc mt-3">
                        Home Fix is your premier destination for top-notch smart home service and repair.
                    </p>

                    <div class="footer-social d-flex gap-3 mt-3">
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" aria-label="Email"><i class="bi bi-envelope"></i></a>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="row">
                        <div class="col-6 col-md-4 ms-md-auto">
                            <h6 class="footer-heading">Company</h6>
                            <ul class="footer-links">
                                <li><a href="#">About us</a></li>
                                <li><a href="#">Services</a></li>
                                <li><a href="#">Our Blog</a></li>
                                <li><a href="#">Contact</a></li>
                            </ul>
                        </div>

                        <div class="col-6 col-md-4">
                            <h6 class="footer-heading">Legal</h6>
                            <ul class="footer-links">
                                <li><a href="#">Terms</a></li>
                                <li><a href="#">Privacy</a></li>
                                <li><a href="#">Cookies</a></li>
                                <li><a href="#">License</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="footer-line">

            <p class="footer-copy text-center mb-0">
                Made with <i class="bi bi-heart-fill"></i> by MMMSN TEAM
            </p>
        </div>
    </footer>

 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
  

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="//cdn.datatables.net/1.13.3/js/jquery.dataTables.min.js" asp-append-version="true"></script>

    <script src="https://cdn.tiny.cloud/1/4e0jbuijq9tssu470d0jvg73zxysdp8jmb9d7hn6paxxkf3s/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  
    <script>
     
        const nav = document.getElementById("mainNav");
        const header = document.getElementById("heroHeader");

        function handleSticky() {
            if (header) {
                const headerBottom = header.offsetTop + header.offsetHeight;
                const scrolled = window.scrollY;

                if (scrolled >= headerBottom) {
                    nav.classList.add("nav-sticky");
                    document.body.classList.add("has-sticky");
                } else {
                    nav.classList.remove("nav-sticky");
                    document.body.classList.remove("has-sticky");
                }
            }
        }

        window.addEventListener("scroll", handleSticky);
        window.addEventListener("load", handleSticky);
        window.addEventListener("resize", handleSticky);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

