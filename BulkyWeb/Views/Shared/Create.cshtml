@model Feedback

<style>
    .feedback-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        padding: 60px 0;
        margin-bottom: 50px;
        margin-top: 80px;
    }

    .feedback-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

        .feedback-card .card-header {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            padding: 30px;
            border: none;
        }

    .form-control, .form-select {
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        padding: 12px 16px;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.25);
        }

    .form-label {
        color: #1f2937;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        border: none;
        border-radius: 50px;
        padding: 12px 40px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
        }

    .btn-outline-custom {
        border: 2px solid #6b7280;
        color: #6b7280;
        border-radius: 50px;
        padding: 12px 40px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-outline-custom:hover {
            background-color: #6b7280;
            color: white;
            transform: translateY(-2px);
        }

    .star-rating .form-select option {
        padding: 10px;
        font-size: 16px;
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }
</style>

<div class="feedback-hero text-white text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">Share Your Experience</h1>
        <p class="lead">We value your feedback and strive to improve our services</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card feedback-card">
                <div class="card-header text-white text-center">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-chat-heart me-2"></i>Add Your Feedback
                    </h3>
                    <p class="mb-0 mt-2 opacity-75">Tell us about your experience with our service</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="ServiceId" class="form-label">
                                <i class="bi bi-wrench me-1"></i>Which Service Did You Use?
                            </label>
                            <select asp-for="ServiceId"
                                    asp-items="ViewBag.ServiceList"
                                    class="form-select">
                                <option value="">-- Select a Service --</option>
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 star-rating">
                            <label asp-for="Rating" class="form-label">
                                <i class="bi bi-star me-1"></i>How Would You Rate Our Service?
                            </label>
                            <select asp-for="Rating" class="form-select">
                                <option value="">-- Select Your Rating --</option>
                                <option value="5">⭐⭐⭐⭐⭐ Excellent - Exceeded Expectations</option>
                                <option value="4">⭐⭐⭐⭐ Very Good - Met Expectations</option>
                                <option value="3">⭐⭐⭐ Good - Satisfactory</option>
                                <option value="2">⭐⭐ Fair - Needs Improvement</option>
                                <option value="1">⭐ Poor - Unsatisfactory</option>
                            </select>
                            <span asp-validation-for="Rating" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Comment" class="form-label">
                                <i class="bi bi-pencil-square me-1"></i>Share Your Detailed Feedback
                            </label>
                            <textarea asp-for="Comment"
                                      class="form-control"
                                      placeholder="Tell us what you liked, what could be improved, or any suggestions you have..."></textarea>
                            <span asp-validation-for="Comment" class="text-danger small"></span>
                            <small class="text-muted">Your feedback helps us serve you better</small>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 flex-wrap gap-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Feedback" asp-action="Index" class="btn btn-outline-custom">
                                    <i class="bi bi-arrow-left me-2"></i>Cancel
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-custom">
                                    <i class="bi bi-arrow-left me-2"></i>Cancel
                                </a>
                            }
                            <button type="submit" class="btn btn-primary-custom">
                                <i class="bi bi-send-fill me-2"></i>Submit Feedback
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted">
                    <i class="bi bi-shield-check me-1"></i>
                    Your feedback is confidential and helps us improve
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
