@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav d-flex align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="icon-btn mx-2 me-3">
            <a id="manage" class="nav-link btn-icon" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                <i class="bi bi-person-circle"></i>
            </a>
        </li>
        <li class="nav-item">
            <form id="logoutForm" class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-outline-danger px-3 btn-soft">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a id="login" asp-area="Identity" asp-page="/Account/Login" class="btn btn-custom-outline px-4 mx-1">
                Login
            </a>
        </li>

        <li class="nav-item">
            <a id="register" asp-area="Identity" asp-page="/Account/Register" class="btn btn-custom-outline px-4 mx-1">
                SignUp
            </a>
        </li>
    }
</ul>

<style>
   
    :root {
        --brand-blue: #007bff;
    }

    .btn-custom-outline {
        border-radius: 15px; 
        font-weight: 500;
        transition: all 0.3s ease;
        border: 1.5px solid var(--brand-blue);
        background-color: transparent;
        color: var(--brand-blue) !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

        
        .btn-custom-outline:hover {
            background-color: var(--brand-blue);
            color: #ffffff !important;
            transform: translateY(-1px);
            box-shadow: 0 5px 12px rgba(0, 123, 255, 0.2);
        }

  
    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 1px solid rgba(0,0,0,.1);
        transition: all .2s ease;
    }

        .icon-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,.1);
        }

    .btn-soft {
        border-radius: 12px;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">