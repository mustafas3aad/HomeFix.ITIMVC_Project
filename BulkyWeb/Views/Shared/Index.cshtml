@model IEnumerable<Feedback>

<style>
    .feedback-index-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        padding: 80px 0 100px;
        position: relative;
        overflow: hidden;
        margin-top: 80px;
    }

        .feedback-index-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="50" r="2" fill="white" opacity="0.1"/></svg>');
            opacity: 0.3;
        }

    .stats-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        margin-top: -50px;
        position: relative;
        z-index: 10;
    }

    .feedback-table-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .table thead th {
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        color: #1f2937;
        font-weight: 600;
        border: none;
        padding: 15px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f3f4f6;
    }

        .table tbody tr:hover {
            background-color: #f9fafb;
            transform: scale(1.01);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

    .btn-add-feedback {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        border: none;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        color: white;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        transition: all 0.3s ease;
    }

        .btn-add-feedback:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
            color: white;
        }

    .btn-view-details {
        background: transparent;
        border: 2px solid #3b82f6;
        color: #3b82f6;
        border-radius: 25px;
        padding: 6px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-view-details:hover {
            background: #3b82f6;
            color: white;
            transform: translateY(-2px);
        }

    .rating-stars i {
        font-size: 18px;
    }

    .service-badge {
        background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
        color: white;
        padding: 6px 15px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .user-badge {
        background: #f3f4f6;
        color: #1f2937;
        padding: 6px 12px;
        border-radius: 15px;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

    .empty-state-icon {
        font-size: 80px;
        color: #cbd5e1;
        margin-bottom: 20px;
    }

    .stat-item {
        text-align: center;
        padding: 15px;
    }

    .stat-number {
        font-size: 32px;
        font-weight: 700;
        color: #2563eb;
        display: block;
    }

    .stat-label {
        color: #6b7280;
        font-size: 14px;
        margin-top: 5px;
    }
</style>

<div class="feedback-index-hero text-white">
    <div class="container text-center position-relative">
        <h1 class="display-3 fw-bold mb-3">Customer Feedback</h1>
        <p class="lead mb-0">See what our clients are saying about our services</p>
    </div>
</div>

<div class="container" style="margin-top: -30px;">
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="stats-card mb-4">
        <div class="row">
            <div class="col-md-4 stat-item">
                <i class="bi bi-chat-dots-fill text-primary" style="font-size: 40px;"></i>
                <span class="stat-number">@Model.Count()</span>
                <div class="stat-label">Total Feedbacks</div>
            </div>
            <div class="col-md-4 stat-item border-start border-end">
                <i class="bi bi-star-fill text-warning" style="font-size: 40px;"></i>
                <span class="stat-number">
                    @if (Model.Any())
                    {
                        @Model.Average(f => f.Rating).ToString("0.0")
                    }
                    else
                    {
                        <text>0.0</text>
                    }
                </span>
                <div class="stat-label">Average Rating</div>
            </div>
            <div class="col-md-4 stat-item">
                <i class="bi bi-people-fill text-success" style="font-size: 40px;"></i>
                <span class="stat-number">@Model.Select(f => f.UserName).Distinct().Count()</span>
                <div class="stat-label">Happy Customers</div>
            </div>
        </div>
    </div>

    <div class="card feedback-table-card">
        <div class="card-body p-0">
            <div class="p-4 d-flex justify-content-between align-items-center border-bottom">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-list-ul me-2 text-primary"></i>All Feedbacks
                </h4>
                <a asp-action="Create" class="btn btn-add-feedback">
                    <i class="bi bi-plus-circle me-2"></i>Add New Feedback
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th><i class="bi bi-person me-1"></i>Customer</th>
                                <th><i class="bi bi-tools me-1"></i>Service</th>
                                <th><i class="bi bi-chat-text me-1"></i>Feedback</th>
                                <th><i class="bi bi-star me-1"></i>Rating</th>
                                <th><i class="bi bi-calendar-event me-1"></i>Date</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderByDescending(f => f.CreatedAt))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                                 style="width: 35px; height: 35px; font-weight: 600;">
                                                @item.UserName.Substring(0, 1).ToUpper()
                                            </div>
                                            <span class="user-badge">@item.UserName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="service-badge">
                                            <i class="bi bi-gear-fill me-1"></i>@item.Service?.Name
                                        </span>
                                    </td>
                                    <td>
                                        <div style="max-width: 300px;">
                                            @if (item.Comment != null && item.Comment.Length > 60)
                                            {
                                                <span class="text-muted">@(item.Comment.Substring(0, 60))...</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">@item.Comment</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="rating-stars">
                                            @for (int i = 0; i < item.Rating; i++)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            @for (int i = item.Rating; i < 5; i++)
                                            {
                                                <i class="bi bi-star text-muted"></i>
                                            }
                                            <small class="text-muted ms-1">(@item.Rating/5)</small>
                                        </div>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>@item.CreatedAt.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-view-details btn-sm">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="bi bi-chat-square-text"></i>
                    </div>
                    <h4 class="fw-bold mb-2">No Feedback Yet</h4>
                    <p class="text-muted mb-4">Be the first to share your experience!</p>
                    <a asp-action="Create" class="btn btn-add-feedback btn-lg">
                        <i class="bi bi-plus-circle me-2"></i>Add First Feedback
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="py-5"></div>
